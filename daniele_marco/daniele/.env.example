# ContractIQ Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# LLM CONFIGURATION (Choose ONE)
# ============================================

# Option 1: Your external LLM API (recommended for hackathon)
# Replace with your actual API endpoint
EXTERNAL_LLM_URL=http://localhost:11434
EXTERNAL_LLM_MODEL=llama3.2:3b

# Option 2: Anthropic API (for Voyage embeddings + fallback)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================
# DATABASE & STORAGE
# ============================================

CHROMA_TOKEN=contractiq-secret
POSTGRES_USER=contractiq
POSTGRES_PASSWORD=contractiq_dev_password
POSTGRES_DB=contractiq

# ============================================
# DSPY OPTIMIZATION
# ============================================

FEEDBACK_THRESHOLD=20
OPTIMIZED_MODELS_PATH=/app/optimized_models

# ============================================
# TIMEOUTS (seconds)
# ============================================

HTTP_TIMEOUT=120
CHAT_TIMEOUT=60
PARSE_TIMEOUT=180
